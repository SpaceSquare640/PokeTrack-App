{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PokeTrack",
  "version": "1.7.0",
  "identifier": "com.spacesquare640.poketrack",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "SpaceSquare640",
    "category": "Utility",
    "shortDescription": "Pokémon GO community activity monitor",
    "longDescription": "PokéTrack — an unofficial Pokémon GO community activity monitor. Tracks live and upcoming events with reminders, calendar export, and multi-language support.",
    "resources": [
      "binaries/poketrack-server.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
